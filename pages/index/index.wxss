.page-index{background:linear-gradient(180deg,#E8F4FD 0%,#F5F5F5 60%);padding:0 32px 40px}.hero{display:flex;flex-direction:column;align-items:center;padding-top:80px;padding-bottom:48px}.logo-ring{width:100px;height:100px;background:linear-gradient(135deg,#4A90E2,#6BB5FF);border-radius:28px;display:flex;align-items:center;justify-content:center;box-shadow:0 12px 32px rgba(74,144,226,.35);margin-bottom:24px}.logo-emoji{font-size:54px}.title{font-size:28px;font-weight:700;color:#1a1a2e;margin-bottom:8px}.subtitle{font-size:14px;color:#888}.feature-list{display:flex;flex-direction:column;gap:14px;margin-bottom:40px}.feature-card{display:flex;align-items:center;gap:16px;background:rgba(255,255,255,.85);border-radius:16px;padding:20px}.feature-icon{font-size:32px;flex-shrink:0}.feature-info{display:flex;flex-direction:column}.feature-title{font-size:15px;font-weight:600;color:#1a1a2e;margin-bottom:4px}.feature-desc{font-size:13px;color:#888}.bottom-area{display:flex;flex-direction:column;gap:14px;align-items:center}.agreement{font-size:11px;color:#bbb;text-align:center}
